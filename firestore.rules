rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Simplest possible rules for development to avoid permission errors
    match /users/{userId} {
      // Read: any authenticated user can view all profile maps for ranking
      allow read, list: if request.auth != null;
      
      // Write: only the authenticated owner can create/update their own profile
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }
    
    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
