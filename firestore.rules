rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Firebase Auth UID)
    // Fields:
    //   - uid: string (required) - User's unique ID
    //   - username: string (required) - Display name
    //   - trophies: number (required) - Current trophy count
    //   - gold: number (required) - Current gold amount
    //   - cardLevels: map (optional) - Card levels
    //   - unlockedCards: list (optional) - Unlocked card IDs
    //   - fragments: map (optional) - Fragment counts
    //   - updatedAt: timestamp (optional) - Last update time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'username', 'trophies', 'gold']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.username is string && data.username.size() <= 20 &&
             data.trophies is number && data.trophies >= 0 &&
             data.gold is number && data.gold >= 0;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }
  }
}
